# Copy to .env and set your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: model id — free tier has per-model quotas; switch if you get 429
# https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-2.5-flash
# Optional: Flash model for triage_agent.py (defaults to gemini-1.5-flash if unset)
# TRIAGE_MODEL=gemini-2.5-flash
