# Copy to .env (repo root)

GEMINI_API_KEY=
# Model for triage (Flash). Falls back: TRIAGE_MODEL → GEMINI_MODEL → FLASH_MODEL → default below.
GEMINI_MODEL=gemini-2.5-flash
# TRIAGE_MODEL=gemini-2.5-flash

# Pro model for root_cause (optional; default gemini-2.5-pro)
# ROOT_CAUSE_MODEL=gemini-2.5-pro
# PRO_MODEL=gemini-2.5-pro
