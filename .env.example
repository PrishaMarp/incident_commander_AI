# Copy to .env (repo root)

GEMINI_API_KEY=

# Triage (Flash). Each model id has its own free-tier quota — if you see 429, switch ids.
TRIAGE_MODEL=gemini-2.0-flash
TRIAGE_FALLBACK_MODEL=gemini-2.5-flash

# Root cause. On 429/404, retries other configured Flash models automatically.
ROOT_CAUSE_MODEL=gemini-2.5-flash

# Aliases still supported: GEMINI_MODEL, FLASH_MODEL, PRO_MODEL

# --- Frontend (Vite) ---
# Production builds (e.g. Vercel) use SSE for the incident stream — serverless has no WebSocket.
# Set VITE_USE_SSE=false only if you serve the same static build behind something that supports WS.
# VITE_USE_SSE=false
# Optional: WebSocket/SSE base when API is on another origin (otherwise same host).
# VITE_WS_URL=wss://your-api.example.com/ws/incident
